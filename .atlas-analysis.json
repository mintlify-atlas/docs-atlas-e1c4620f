  "keyFeatures": [
    "PIN verification gate before app access with configurable expiry modes (never or duration-based)",
    "Interstitial ad serving via programmatic Android dialogs with zero external dependencies",
    "Impression and click tracking for ad analytics",
    "MT Manager / Smali injection support via DEX packaging",
    "Admin dashboard for managing API keys, ads, PIN configuration, and device verification records",
    "Device-bound PIN generation via shortener link flow",
    "Community links dialog (JoinDialog) with Telegram and channel integration",
    "Canvas-drawn UI icons — no image assets required"
  ],
  "publicApiSurface": [
